# Fabricator production environment — copy to .env and fill in values
# Generate secrets: openssl rand -hex 32

# --- Domain (for CORS + SSL setup) ---
DOMAIN=yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# --- PostgreSQL (used by docker-compose) ---
POSTGRES_USER=fabricator
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=fabricator

# --- Flask / API ---
FLASK_ENV=production
SECRET_KEY=CHANGE_ME_OPENSSL_RAND_HEX_32
JWT_SECRET_KEY=CHANGE_ME_OPENSSL_RAND_HEX_32
JWT_EXPIRE_DAYS=7

# --- First trainer account (created on first deploy) ---
TRAINER_EMAIL=trainer@yourdomain.com
TRAINER_PASSWORD=CHANGE_ME_STRONG_TRAINER_PASSWORD

# --- Set true only for local/demo installs ---
SEED_DEMO_DATA=false

# --- Optional tuning ---
GUNICORN_WORKERS=4
LOG_LEVEL=info
